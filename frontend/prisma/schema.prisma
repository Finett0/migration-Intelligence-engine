generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id         String   @id @default(cuid())
  url        String
  email      String?
  phone      String?
  platform   String?
  revenue    String?
  pains      String[]
  storeTitle String?
  score      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  events     Event[]

  @@unique([url, email])
  @@index([score(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Event {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  type      String   // "analysis" | "pdf_download" | "email_sent" | "email_open"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}
